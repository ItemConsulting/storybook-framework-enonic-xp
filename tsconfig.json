{
  "compilerOptions": {
    "target": "ES2024",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "declaration": true,
    "skipLibCheck": true,
    "lib": ["ES2024"],
    "rootDir": "src",
    "outDir": "dist"
  },
  "include": ["src"]
}
